<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    ╔══════════════════════════════════════════════════════════╗
    ║   ALL TOPICS — Full Test Suite                          ║
    ║   একটার পর একটা sequence এ চলবে                        ║
    ║                                                         ║
    ║   Run করো:                                             ║
    ║   IntelliJ → Run → Edit Configurations                 ║
    ║   → (+) TestNG → Suite → এই XML select করো            ║
    ╚══════════════════════════════════════════════════════════╝
-->

<suite name="All-Topics-Suite"
       verbose="2"
       parallel="none">

    <!-- ══════════════════════════════════════════════
         TOPIC 1 — Mock / Network Interception
    ══════════════════════════════════════════════ -->
    <test name="Topic1: 1A Mock API Response">
        <classes>
            <class name="MockNetworkTest">
                <methods><include name="test1A_MockApiResponse"/></methods>
            </class>
        </classes>
    </test>

    <test name="Topic1: 1B Modify Real Response">
        <classes>
            <class name="MockNetworkTest">
                <methods><include name="test1B_ModifyRealResponse"/></methods>
            </class>
        </classes>
    </test>

    <test name="Topic1: 1C Slow Network">
        <classes>
            <class name="MockNetworkTest">
                <methods><include name="test1C_SlowNetwork"/></methods>
            </class>
        </classes>
    </test>

    <test name="Topic1: 1D 500 Error Injection">
        <classes>
            <class name="MockNetworkTest">
                <methods><include name="test1D_500ErrorInjection"/></methods>
            </class>
        </classes>
    </test>

    <test name="Topic1: 1E Image Block">
        <classes>
            <class name="MockNetworkTest">
                <methods><include name="test1E_RequestBlock"/></methods>
            </class>
        </classes>
    </test>

